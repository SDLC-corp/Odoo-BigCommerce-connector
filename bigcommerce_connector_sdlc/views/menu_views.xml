<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_bigcommerce_delivery_orders" model="ir.actions.act_window">
            <field name="name">Delivery Orders</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('picking_type_code', '=', 'outgoing'), ('sale_id', '!=', False), ('sale_id.origin', 'ilike', 'BigCommerce #')]</field>
        </record>

        <record id="action_bigcommerce_tracking" model="ir.actions.act_window">
            <field name="name">BigCommerce Tracking</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('picking_type_code', '=', 'outgoing'), ('state', '=', 'done'), ('sale_id', '!=', False), ('sale_id.origin', 'ilike', 'BigCommerce #')]</field>
        </record>

        <menuitem
            id="menu_bigcommerce_root"
            name="BigCommerce"
            sequence="35"
            action="bigcommerce_connector_sdlc.action_bigcommerce_dashboard"
            groups="base.group_user"
        />

        <menuitem
            id="menu_bigcommerce_dashboard"
            name="Dashboard"
            parent="menu_bigcommerce_root"
            sequence="5"
            action="bigcommerce_connector_sdlc.action_bigcommerce_dashboard"
            groups="base.group_user"
        />

        <menuitem
            id="menu_bigcommerce_connectors"
