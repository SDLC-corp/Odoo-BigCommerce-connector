        <!-- Shipping menu hidden by default: shipment export still works from connector actions/automation -->
        <record id="menu_bigcommerce_shipping" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <record id="menu_bigcommerce_delivery_orders" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <record id="menu_bigcommerce_tracking" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <menuitem
