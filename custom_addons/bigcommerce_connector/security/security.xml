<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_bigcommerce" model="ir.module.category">
            <field name="name">BigCommerce</field>
            <field name="sequence">30</field>
        </record>

        <record id="group_bigcommerce_user" model="res.groups">
            <field name="name">BigCommerce User</field>
            <field name="category_id" ref="bigcommerce_connector.module_category_bigcommerce"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_bigcommerce_manager" model="res.groups">
            <field name="name">BigCommerce Manager</field>
            <field name="category_id" ref="bigcommerce_connector.module_category_bigcommerce"/>
            <field name="implied_ids" eval="[(4, ref('bigcommerce_connector.group_bigcommerce_user'))]"/>
        </record>
    </data>
</odoo>
