<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bigcommerce_product_binding_list" model="ir.ui.view">
            <field name="name">bigcommerce.product.binding.list</field>
            <field name="model">bigcommerce.product.binding</field>
            <field name="arch" type="xml">
                <list string="Product Bindings">
                    <field name="instance_id"/>
                    <field name="product_tmpl_id" string="Name"/>
                    <field name="bigcommerce_is_featured" string="Featured"/>
                    <field name="bigcommerce_sku" string="SKU"/>
                    <field name="odoo_category_name" string="Categories"/>
                    <field name="current_stock" string="Current Stock"/>
                    <field name="default_price" string="Default Price"/>
                    <field name="calculated_price" string="Calculated Price"/>
                    <field name="channel_name" string="Channels"/>
                    <field name="visibility_label" string="Visibility"/>
                    <field name="bigcommerce_product_id"/>
                    <field name="sync_state"/>
                    <field name="last_synced_at"/>
                </list>
            </field>
        </record>

        <record id="view_bigcommerce_product_binding_form" model="ir.ui.view">
            <field name="name">bigcommerce.product.binding.form</field>
            <field name="model">bigcommerce.product.binding</field>
            <field name="arch" type="xml">
                <form string="Product Binding">
                    <sheet>
                        <group>
                            <group>
                                <field name="instance_id"/>
                                <field name="product_tmpl_id"/>
                                <field name="product_id"/>
                                <field name="bigcommerce_is_featured"/>
                                <field name="bigcommerce_is_visible"/>
                                <field name="sync_state"/>
                            </group>
                            <group>
                                <field name="bigcommerce_product_id"/>
                                <field name="bigcommerce_variant_id"/>
                                <field name="bigcommerce_sku"/>
                                <field name="odoo_category_name" readonly="1"/>
                                <field name="current_stock" readonly="1"/>
                                <field name="default_price" readonly="1"/>
                                <field name="calculated_price" readonly="1"/>
                                <field name="channel_name" readonly="1"/>
                                <field name="visibility_label" readonly="1"/>
                                <field name="last_synced_at" readonly="1"/>
                            </group>
                        </group>
                        <group string="Error">
                            <field name="last_error" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bigcommerce_product_binding_search" model="ir.ui.view">
            <field name="name">bigcommerce.product.binding.search</field>
            <field name="model">bigcommerce.product.binding</field>
            <field name="arch" type="xml">
                <search string="Product Bindings">
                    <field name="search_term" string="Search"/>
                    <field name="instance_id"/>
                    <field name="sync_state"/>
                    <field name="bigcommerce_sku"/>
                    <field name="bigcommerce_variant_id"/>
                    <field name="product_tmpl_id"/>
                    <field name="product_id"/>
                    <filter name="filter_state_draft" string="Draft" domain="[('sync_state', '=', 'draft')]"/>
                    <filter name="filter_state_synced" string="Synced" domain="[('sync_state', '=', 'synced')]"/>
                    <filter name="filter_state_error" string="Error" domain="[('sync_state', '=', 'error')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_instance" string="Instance" context="{'group_by': 'instance_id'}"/>
                        <filter name="group_by_state" string="Sync State" context="{'group_by': 'sync_state'}"/>
                        <filter name="group_by_template" string="Template" context="{'group_by': 'product_tmpl_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_bigcommerce_inventory_binding_list" model="ir.ui.view">
            <field name="name">bigcommerce.inventory.binding.list</field>
            <field name="model">bigcommerce.product.binding</field>
            <field name="arch" type="xml">
                <list string="Inventory">
                    <field name="instance_id"/>
                    <field name="product_tmpl_id" string="Product"/>
                    <field name="bigcommerce_sku" string="SKU"/>
                    <field name="current_stock" string="Current Stock"/>
                    <field name="bigcommerce_inventory_level" string="BigCommerce Stock"/>
                    <field name="sync_state"/>
                    <field name="last_synced_at"/>
                </list>
            </field>
        </record>

        <record id="action_bigcommerce_product_binding" model="ir.actions.act_window">
            <field name="name">Product Bindings</field>
            <field name="res_model">bigcommerce.product.binding</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_bigcommerce_product_binding_search"/>
            <field name="domain">[('bigcommerce_variant_id', '=', False), ('instance_id.company_id', 'in', context.get('allowed_company_ids') or [context.get('company_id')])]</field>
        </record>

        <record id="action_bigcommerce_inventory_binding" model="ir.actions.act_window">
            <field name="name">Inventory</field>
            <field name="res_model">bigcommerce.product.binding</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_bigcommerce_inventory_binding_list"/>
            <field name="search_view_id" ref="view_bigcommerce_product_binding_search"/>
            <field name="domain">[('bigcommerce_variant_id', '=', False), ('instance_id.company_id', 'in', context.get('allowed_company_ids') or [context.get('company_id')])]</field>
        </record>
    </data>
</odoo>
