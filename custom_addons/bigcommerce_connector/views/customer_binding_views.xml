<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bigcommerce_customer_binding_list" model="ir.ui.view">
            <field name="name">bigcommerce.customer.binding.list</field>
            <field name="model">bigcommerce.customer.binding</field>
            <field name="arch" type="xml">
                <list string="Customer Bindings">
                    <field name="instance_id"/>
                    <field name="partner_id"/>
                    <field name="email"/>
                    <field name="bigcommerce_customer_id"/>
                    <field name="sync_state"/>
                    <field name="last_synced_at"/>
                </list>
            </field>
        </record>

        <record id="view_bigcommerce_customer_binding_form" model="ir.ui.view">
            <field name="name">bigcommerce.customer.binding.form</field>
            <field name="model">bigcommerce.customer.binding</field>
            <field name="arch" type="xml">
                <form string="Customer Binding">
                    <sheet>
                        <group>
                            <group>
                                <field name="instance_id"/>
                                <field name="partner_id"/>
                                <field name="email"/>
                                <field name="sync_state"/>
                            </group>
                            <group>
                                <field name="bigcommerce_customer_id"/>
                                <field name="last_synced_at" readonly="1"/>
                            </group>
                        </group>
                        <group string="Error">
                            <field name="last_error" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bigcommerce_customer_binding_search" model="ir.ui.view">
            <field name="name">bigcommerce.customer.binding.search</field>
            <field name="model">bigcommerce.customer.binding</field>
            <field name="arch" type="xml">
                <search string="Customer Bindings">
                    <field name="instance_id"/>
                    <field name="sync_state"/>
                    <field name="partner_id"/>
                    <field name="email"/>
                    <field name="bigcommerce_customer_id"/>
                    <filter name="filter_state_draft" string="Draft" domain="[('sync_state', '=', 'draft')]"/>
                    <filter name="filter_state_synced" string="Synced" domain="[('sync_state', '=', 'synced')]"/>
                    <filter name="filter_state_error" string="Error" domain="[('sync_state', '=', 'error')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_instance" string="Instance" context="{'group_by': 'instance_id'}"/>
                        <filter name="group_by_state" string="Sync State" context="{'group_by': 'sync_state'}"/>
                        <filter name="group_by_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_bigcommerce_customer_binding" model="ir.actions.act_window">
            <field name="name">Customer Bindings</field>
            <field name="res_model">bigcommerce.customer.binding</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_bigcommerce_customer_binding_search"/>
        </record>
    </data>
</odoo>
