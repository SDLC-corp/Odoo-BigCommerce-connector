<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bigcommerce_field_mapping_test_wizard_form" model="ir.ui.view">
            <field name="name">bigcommerce.field.mapping.test.wizard.form</field>
            <field name="model">bigcommerce.field.mapping.test.wizard</field>
            <field name="arch" type="xml">
                <form string="Test Mapping Result">
                    <group>
                        <field name="mapping_id"/>
                    </group>
                    <group>
                        <field name="sample_payload" widget="text"/>
                        <field name="mapped_result" widget="text"/>
                    </group>
                    <footer>
                        <button string="Close" class="btn-primary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
