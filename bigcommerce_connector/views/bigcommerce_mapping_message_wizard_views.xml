<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bigcommerce_mapping_message_wizard_form" model="ir.ui.view">
            <field name="name">bigcommerce.mapping.message.wizard.form</field>
            <field name="model">bigcommerce.mapping.message.wizard</field>
            <field name="arch" type="xml">
                <form string="Mapping Status">
                    <group>
                        <field name="title" readonly="1"/>
                    </group>
                    <group>
                        <field name="message" readonly="1" widget="text"/>
                    </group>
                    <footer>
                        <button string="OK" class="btn-primary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
